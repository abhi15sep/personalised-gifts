# Database
DATABASE_URL="mysql://root:password@localhost:3306/personalised_gifts"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@personalisedgifts.co.uk

# Support
SUPPORT_EMAIL=your-email@example.com

# PhonePe
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# Tink Pay by Bank (Payment Initiation — no settlement account needed)
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
TINK_DEST_ACCOUNT_NUMBER=12345678
TINK_DEST_SORT_CODE=040004
TINK_PAYEE_NAME=PersonalisedGifts
TINK_MARKET=GB
TINK_LOCALE=en_GB
TINK_REDIRECT_URI=http://localhost:3000/checkout/tink-return
TINK_WEBHOOK_SECRET=
TINK_ENV=sandbox

# Tawk.to Live Chat
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
